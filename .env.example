# Drip Environment Variables

# PayWithLocus API key (claw_dev_* prefix)
LOCUS_API_KEY=claw_dev_YOUR_KEY_HERE

# BuildWithLocus API key (same or different claw_dev_* key)
BWL_API_KEY=claw_dev_YOUR_KEY_HERE

# Mock drain mode: set to "true" during development to avoid real API costs
MOCK_DRAIN=true

# Polling interval in seconds (60 for prod, 5 for demo mode)
POLL_INTERVAL_SECONDS=60

# AgentMail inbox address
AGENTMAIL_INBOX=your-inbox@agentmail.to

# GHCR image for research container
GHCR_IMAGE=ghcr.io/0xshae/locusmeter-research:latest

# API base URLs (beta environment)
LOCUS_API_BASE=https://beta-api.paywithlocus.com/api
BWL_API_BASE=https://api.buildwithlocus.com

# Port (injected by BWL, default 8080)
PORT=8080

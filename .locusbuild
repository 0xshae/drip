{
  "services": {
    "drip": {
      "port": 8080,
      "healthCheck": "/health",
      "env": {
        "MOCK_DRAIN": "true",
        "POLL_INTERVAL_SECONDS": "60",
        "LOCUS_API_BASE": "https://beta-api.paywithlocus.com/api",
        "BWL_API_BASE": "https://beta-api.buildwithlocus.com"
      }
    }
  }
}

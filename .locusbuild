{
  "services": [
    {
      "name": "drip",
      "source": {
        "type": "github"
      },
      "buildConfig": {
        "method": "dockerfile",
        "dockerfile": "Dockerfile"
      },
      "runtime": {
        "port": 8080,
        "cpu": 256,
        "memory": 512,
        "minInstances": 1,
        "maxInstances": 1
      },
      "healthCheckPath": "/health",
      "autoDeploy": true,
      "env": {
        "MOCK_DRAIN": "true",
        "POLL_INTERVAL_SECONDS": "60",
        "LOCUS_API_BASE": "https://beta-api.paywithlocus.com/api",
        "BWL_API_BASE": "https://beta-api.buildwithlocus.com"
      }
    }
  ]
}
